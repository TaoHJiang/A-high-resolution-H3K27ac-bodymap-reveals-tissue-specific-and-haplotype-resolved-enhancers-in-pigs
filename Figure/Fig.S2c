library(ggplot2)

pdf("test.pdf", width = 6, height = 1.5)

ggplot(df) + 
  geom_bar(aes(x = group, y = value, fill = group2), 
           stat = "identity", 
           width = 0.75, 
           position = "fill") +  
  scale_y_continuous(expand = c(0, 0)) +  
  theme_classic() +  
  coord_flip()  
dev.off()
